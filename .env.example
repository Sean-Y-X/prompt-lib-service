# Neon Postgres (or any Postgres) connection string — REQUIRED.
# Use the pooled connection string from your Neon project dashboard.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Google Gemini API key for AI-assisted prompt drafting — OPTIONAL.
# The app works fully without it; only the "Draft with AI" button needs it.
# Get a free key at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=""
